{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reclaude",
  "version": "1.0.0",
  "identifier": "dev.reclaude.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Reclaude",
        "width": 760,
        "height": 620,
        "minWidth": 640,
        "minHeight": 520,
        "resizable": true,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
